createthread(Teleport)
registersymbol(TPmath)
alloc(Teleport,$1000)
alloc(TPmath,$18)

TPmath+10:
dd 2,(float)0.3

Teleport:
  cmp [TPmath+10],2
  je code
  cmp [TPmath+10],1
  jne Teleport

  push eax
  mov eax,[localplayer]
  mov eax,[eax+28C]
  mov [eax+18],0
  mov [eax+1C],0
  mov [eax+20],0
  mov eax,[localplayer]
  mov eax,[eax+290]
  movss xmm0,[TPmath+00]
  subss xmm0,[TPmath+14]
  movss [eax+00],xmm0
  addss xmm0,[eax+18]
  movss [eax+0C],xmm0

  movss xmm0,[TPmath+04]
  movss [eax+04],xmm0
  addss xmm0,[eax+1C]
  movss [eax+10],xmm0

  movss xmm0,[TPmath+08]
  subss xmm0,[TPmath+14]
  movss [eax+08],xmm0
  addss xmm0,[eax+18]
  movss [eax+14],xmm0

  mov [TPmath+10],0
  pop eax
  jmp Teleport

code:
  push eax
  mov eax,[localplayer]
  mov eax,[eax+290]
  movss xmm0,[eax+00]
  addss xmm0,[TPmath+14]
  movss [TPmath+00],xmm0
  movss xmm0,[eax+04]
  movss [TPmath+04],xmm0
  movss xmm0,[eax+08]
  addss xmm0,[TPmath+14]
  movss [TPmath+08],xmm0
  mov [TPmath+10],0
  pop eax
  jmp Teleport


[DISABLE]
Teleport:
retn// Enifmmr 2024/6/30
unregistersymbol(TPmath)
