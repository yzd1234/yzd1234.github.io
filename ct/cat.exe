  <UserdefinedSymbols/>
  <LuaScript>function cycleFullCompact( sender, force )


    local state = not( compactmenuitem.Caption == '界面' )


    if force ~= nil then state = not force end


    compactmenuitem.Caption = state and '界面'or'修改'
    getMainForm().Splitter1.Visible = state

    getMainForm().Panel4.Visible = state
    getMainForm().Panel5.Visible = state

  end








  function addCompactMenu()
    if compactmenualreadyexists then return end
      local parent = getMainForm().Menu.Items

      compactmenuitem = createMenuItem( parent )
      parent.add( compactmenuitem )

      compactmenuitem.Caption = '界面'
      compactmenuitem.OnClick = cycleFullCompact


      compactmenualreadyexists = 'yes'
  end

  addCompactMenu()

  cycleFullCompact(nil,true)

function cycleFullCompact()
  getMainForm().Splitter1.Visible = state
  getMainForm().Panel4.Visible    = state
  getMainForm().Panel5.Visible    = state
  getMainForm().Panel7.Visible    = state
end

function addCompactMenu()
  if compactmenualreadyexists then return end
  local parent = getMainForm().Menu.Items
  compactmenuitem = createMenuItem(parent); parent.add(compactmenuitem)
end

function zz()
showMessage("作者:元時光")
end

function zzz()
showMessage("主人还不去自裁吗?")

end


function AttachProcess()
   openProcess('Minecraft.Windows.exe')
if getProcessIDFromProcessName('Minecraft.Windows.exe') ~= nil then
      openProcess('Minecraft.Windows.exe')
      att.ShowHint = true
	  att.Enabled = true
      att.Caption = '插入成功'
      showMessage("插入成功,下次轻点喵~")
   else
      showMessage("主人请把MC打开了来,喵~")
   end
end

function time()
timer = tonumber(inputQuery('修改速度', '要修改的速度','1'))
speedhack_setSpeed(timer)
showMessage("主人,变速修改成功喵")
end

getMainForm().caption = "猫娘自裁 in CE 2.0"

--- create a form
panel = createPanel(getMainForm())
panel.Width = 160
panel.Align = alLeft
--- create a button (as a object) inside that form
att = createButton(panel) -- object name for button = MyButton
--- top + 45
att.Left = 0
att.Top = 98
att.Width = 160
att.Height = 100
att.Caption = '暴力插入'  -- Put text on the button
att.onClick = AttachProcess

tpb = createButton(panel)
tpb.Left = 0
tpb.Top = 0
tpb.Width = 160
tpb.Height = 100
tpb.Caption = '变速'
tpb.onClick = time

t = createButton(panel)
t.Left = 10
t.Top = 210
t.Width = 60
t.Height = 60
t.Caption = '作者'
t.onClick = zz

t = createButton(panel)
t.Left = 90
t.Top = 210
t.Width = 60
t.Height = 60
t.Caption = '?'
t.onClick = zzz

addCompactMenu()
cycleFullCompact()

</LuaScript>
</CheatTable>
