function cycleFullCompact()
  local state = not(compactmenuitem.Caption == '简易模式')
  compactmenuitem.Caption = state and '简易模式' or '恢复原来界面'
  getMainForm().Splitter1.Visible = state
  getMainForm().Panel4.Visible    = state
  getMainForm().Panel5.Visible    = state
  getMainForm().Panel7.Visible    = state
end


function addCompactMenu()
  if compactmenualreadyexists then return end
  local parent = getMainForm().Menu.Items
  compactmenuitem = createMenuItem(parent); parent.add(compactmenuitem)
  compactmenuitem.Caption = '简易模式'
  compactmenuitem.OnClick = cycleFullCompact
  compactmenualreadyexists = 'yes'
end

addCompactMenu()
cycleFullCompact()








function cycleFullCompact()
  getMainForm().Splitter1.Visible = state
  getMainForm().Panel4.Visible    = state
  getMainForm().Panel5.Visible    = state
  getMainForm().Panel7.Visible    = state
end


function addCompactMenu()
  if compactmenualreadyexists then return end
  local parent = getMainForm().Menu.Items
  compactmenuitem = createMenuItem(parent); parent.add(compactmenuitem)
end

function AttachProcess()
   openProcess('Minecraft.Windows.exe')
if getProcessIDFromProcessName('Minecraft.Windows.exe') ~= nil then
      openProcess('Minecraft.Windows.exe')
      att.ShowHint = true
	  att.Enabled = true
      att.Caption = '已完成注入'
      showMessage("成功注入游戏\r𝑰𝒏𝒋𝒆𝒄𝒕 𝒕𝒉𝒆 𝒈𝒂𝒎𝒆 𝒔𝒖𝒄𝒄𝒆𝒔𝒔𝒇𝒖𝒍𝒍𝒚")
   else
      showMessage("错误，未发现游戏进程\r𝑬𝒓𝒓𝒐𝒓，𝒈𝒂𝒎𝒆 𝒑𝒓𝒐𝒄𝒆𝒔𝒔 𝒏𝒐𝒕 𝒇𝒐𝒖𝒏𝒅")
   end
end



function Timer()
Timer = tonumber(inputQuery('Timer', 'Timer','1'))
speedhack_setSpeed(Timer)
showMessage("修改成功")
end

getMainForm().caption = "◆ MisCerNT_Mod 1.0 Beta ◆"

--- create a form
panel = createPanel(getMainForm())
panel.Width = 160
panel.Align = alLeft
--- create a button (as a object) inside that form
att = createButton(panel) -- object name for button = MyButton
--- top + 45
att.Left = 111111
att.Top = 11111111
att.Width = 70
att.Height = 70
att.Caption = '这段删了会出问题·-·'  -- Put text on the button
att.onClick = AttachProcess

function Fuck()
showMessage("2024/7/30 修复了环绕且兼容了自瞄\n2024/7/31 增加了一些功能 不会相互影响\n2024/8/1 增加了多种lua脚本功能\n2024/8/2 更新功能:船类型 喷射鞘翅 速爬 傻子卡人 受伤不抖\n2024/8/3 更新功能:TP生物 自动疾跑2.0 传送飞行\n2024/8/4 修复了自动搭路 更新功能:自动驾驶[马] 冲刺飞行 [伪]锁Buff\n2024/8/5 部分数值稍作修改 更新功能:无挥手 时间类型 杀戮更换 实体方块渲染 原子运动 自动驾驶[更多] 放大镜[模拟Java版] 穿墙不闪 右键连击\n2024/8/6 更新内容: 天气修改 时间修改黑夜修复 船传送飞 穿墙连跳 自动跳跃 无数据包 [伪]飘浮Buff 反隐身 冲刺飞改F3快捷\n2024/8/7 更新内容: 纵向自动校准视角 视觉矩阵 反黑暗 Tpaura 传送骑人 秒射弓箭 魔幻视角\n2024/8/8 更新内容: 长按丢弃 反失明 无冷却 难度修改 陀螺 转身子 CT界面史诗更新\n\n\n目前版本[1.0正式版 Beta]\n\n\n\n\n永不更新")
end

function bkyy()
showMessage("1.CT功能互相矛盾导致无法启动/崩溃\n2.前置开启再关闭也会崩端\n\n如果还有什么问题可联系作者")
