          <CheatEntries>
            <CheatEntry>
              <ID>1337191133</ID>
              <Description>"超级自瞄"</Description>
              <Options moHideChildren="1"/>
              <Color>0000FF</Color>
              <GroupHeader>1</GroupHeader>
              <CheatEntries>
                <CheatEntry>
                  <ID>21435</ID>
                  <Description>"静态自瞄"</Description>
                  <Color>FF8000</Color>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>{$lua}
t = getAddressList()
x = t.getMemoryRecordByDescription("X1C")
y = t.getMemoryRecordByDescription("Y1C")
z = t.getMemoryRecordByDescription("Z1C")
x1 = t.getMemoryRecordByDescription("xother")
y1 = t.getMemoryRecordByDescription("yother")
z1 = t.getMemoryRecordByDescription("zother")
myX = t.getMemoryRecordByDescription("视角XZ")
myY = t.getMemoryRecordByDescription("视角Y")
range = t.getMemoryRecordByDescription("自瞄距离")
a = 1
b = 1
c = 1
d = 1
e = 1
f = 1
g = 10
[ENABLE]
Aimbot = createTimer()
Aimbot.Interval = 1
speed = 0.0001
Aimbot.OnTimer = function(Aimbot)
  if g == 10 then
  sX, sY, sZ, eX, eY, eZ =x.value,y.value,z.value,x1.value,y1.value,z1.value
  distancezs = math.sqrt((sX-eX)^2+(sY-eY)^2+(sZ-eZ)^2)
  if distancezs + 0 &lt; range.value + 0 then
    d = x1.value - x.value
    a = z1.value - z.value
    e = y1.value - y.value
    c = math.sqrt( a*a + d*d )
    f = math.atan2(e, c)
    b = math.atan2(x1.value - x.value, z1.value - z.value)
    myY.value = 1 * f
    if b &gt;= 0 then
      if a &gt; 0 then
        myX.value = b - 3.14159265359
      end
      if a &lt; 0 then
        myX.value = b - 3.14159265359
      end
    end                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         ---Redc

    if b &lt; 0 then
      if a &lt; 0 then
        myX.value = b + 3.14159265359
      end
      if a &gt; 0 then
        myX.value = b + 3.14159265359
      end
    end
    end
  end
end
[DISABLE]
Aimbot.destroy()
</AssemblerScript>
