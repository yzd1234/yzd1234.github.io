            <CheatEntry>
              <ID>223</ID>
              <Description>"Tpaura[自设快捷键][使用键V]"</Description>
              <Color>0000FF</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>{$lua}
t = getAddressList()
X1 = t.getMemoryRecordByDescription("xself")
Y1 = t.getMemoryRecordByDescription("yself")
Z1 = t.getMemoryRecordByDescription("zself")
X2 = t.getMemoryRecordByDescription("xother")
Y2 = t.getMemoryRecordByDescription("yother")
Z2 = t.getMemoryRecordByDescription("zother")
XM = t.getMemoryRecordByDescription("Xm")
YM = t.getMemoryRecordByDescription("Ym")
ZM = t.getMemoryRecordByDescription("Zm")
[ENABLE]
X3 = X1.value
Y3 = Y1.value
Z3 = Z1.value
TX = X3
TY = Y3
TZ = Z3
tpaura = createTimer()
tpaura.Interval = 1
speed = 1
tpaura.OnTimer = function(tpaura)
if isKeyPressed(VK_V) then
  XM.value = X2.value - X1.value
  YM.value = Y2.value - Y1.value
  ZM.value = Z2.value - Z1.value
  sleep(10)
  XM.value = TX - X1.value
  YM.value = TY - Y1.value
  ZM.value = TZ - Z1.value
end
end
[DISABLE]
tpaura.destroy()
</AssemblerScript>
