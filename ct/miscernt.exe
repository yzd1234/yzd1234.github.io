                <CheatEntry>
                  <ID>1337185020</ID>
                  <Description>"船传送飞"</Description>
                  <Color>00FF00</Color>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>{$lua}
t = getAddressList()
XM = t.getMemoryRecordByDescription("BoatMotion:X")
YM = t.getMemoryRecordByDescription("BoatMotion:Y")
ZM = t.getMemoryRecordByDescription("BoatMotion:Z")
XR = t.getMemoryRecordByDescription('视角XZ')
YR = t.getMemoryRecordByDescription('视角Y')
[ENABLE]
BoatMotion = createTimer()
BoatMotion.Interval = 1
speed = 1
BoatMotion.OnTimer = function(BoatMotion)
YM.value = 0
XM.value = 0
ZM.value = 0
if isKeyPressed(VK_W) then
tempXR = XR.value + math.pi
XM.value = XM.value + (math.sin(tempXR) * 1)
ZM.value = ZM.value + (math.cos(tempXR) * 1)
end
if isKeyPressed(VK_S) then
tempXR = XR.value + math.pi
XM.value = XM.value - (math.sin(tempXR) * 1)
ZM.value = ZM.value - (math.cos(tempXR) * 1)
end
if isKeyPressed(VK_A) then
tempXR = XR.value + math.pi - 1.5707963
XM.value = XM.value - (math.sin(tempXR) * 1)
ZM.value = ZM.value - (math.cos(tempXR) * 1)
end
if isKeyPressed(VK_D) then
tempXR = XR.value + math.pi + 1.5707963
XM.value = XM.value - (math.sin(tempXR) * 1)
ZM.value = ZM.value - (math.cos(tempXR) * 1)
end
if isKeyPressed(VK_UP) then
  YM.value = 0.5
 end
 if isKeyPressed(VK_DOWN) then
  YM.value = -0.5
 end
end
[DISABLE]
BoatMotion.destroy()
</AssemblerScript>
                </CheatEntry>
              </CheatEntries>
            </CheatEntry>
            <CheatEntry>
              <ID>22131</ID>
              <Description>"冲刺飞行[F3]"</Description>
              <Color>00FF00</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>{$lua}
t = getAddressList()
XM = t.getMemoryRecordByDescription("motionX")
YM = t.getMemoryRecordByDescription("motionY")
ZM = t.getMemoryRecordByDescription("motionZ")
XR = t.getMemoryRecordByDescription('视角XZ')
YR = t.getMemoryRecordByDescription('视角Y')
[ENABLE]
tpaura = createTimer()
tpaura.Interval = 1
speed = 2
tpaura.OnTimer = function(tpaura)
tempXR = XR.value + math.pi
XM.value =  math.sin(tempXR)
ZM.value =  math.cos(tempXR)
YM.value = 0
end
[DISABLE]
tpaura.destroy()
</AssemblerScript>
              <Hotkeys>
                <Hotkey>
                  <Action>Toggle Activation</Action>
                  <Keys>
                    <Key>114</Key>
                  </Keys>
                  <ID>0</ID>
                </Hotkey>
              </Hotkeys>
            </CheatEntry>
            <CheatEntry>
              <ID>923</ID>
              <Description>"原子运动[不建议长按跳跃键]"</Description>
              <Color>00FF00</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>{$lua}
[ENABLE]
table = GetAddressList()
xvel = table.getMemoryRecordByDescription('Xm')
yvel = table.getMemoryRecordByDescription('Ym')
zvel = table.getMemoryRecordByDescription('Zm')
xrot = table.getMemoryRecordByDescription('Xsj')
yrot = table.getMemoryRecordByDescription('Ysj')

speed = 2.5

createThread(function()
while (true) do

if isKeyPressed(VK_SPACE) then
yvel.value = 0.5
end

if isKeyPressed(VK_SPACE) then
xrotcalc = xrot.value + math.pi
yrotcalc = yrot.value
hspeed = math.abs(math.cos(yrotcalc) * speed)
xvel.value = math.sin(xrotcalc) * hspeed
zvel.value = math.cos(xrotcalc) * hspeed
end
end
end)

[DISABLE]
</AssemblerScript>
            </CheatEntry>
