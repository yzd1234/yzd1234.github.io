            <CheatEntry>
              <ID>1337193098</ID>
              <Description>"传送飞行[前置单开]"</Description>
              <Options moHideChildren="1"/>
              <Color>00FF00</Color>
              <GroupHeader>1</GroupHeader>
              <Address/>
              <CheatEntries>
                <CheatEntry>
                  <ID>1337193094</ID>
                  <Description>"传送飞行"</Description>
                  <Options moHideChildren="1"/>
                  <Color>808000</Color>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>{$lua}
t = getAddressList()

fovX = t.getMemoryRecordByDescription("FovXZ")
speedd = t.getMemoryRecordByDescription("水平飞行速度")
speedd2 = t.getMemoryRecordByDescription("垂直飞行速度")
FlyDliang = t.getMemoryRecordByDescription("动量Y")
FlyXDliang = t.getMemoryRecordByDescription("动量X")
FlyZDliang = t.getMemoryRecordByDescription("动量Z")


local base =getAddress("[KaioDL]")
a,b,c,d = 0,0,0,0
s,v = 0,0
if speedd.value + 0 == 0 then
speedd.value = 1.5
end

if speedd2.value + 0 == 0 then
speedd2.value = 1
end
[ENABLE]
goodFlay = createTimer()
goodFlay.Interval = 1
goodFlay.OnTimer = function(Test233)





lopp = speedd2.value


if isKeyPressed(VK_W) then
a = 1
XR1 = fovX.value + math.pi
writeFloat(base+0x0,math.sin(XR1)*speedd.value)
writeFloat(base+0x8,math.cos(XR1)*speedd.value)
else
a = 0
end

if isKeyPressed(VK_A) then
b = 1
XR1 = fovX.value + math.pi+ 1.5707963
writeFloat(base+0x0,math.sin(XR1)*speedd.value)
writeFloat(base+0x8,math.cos(XR1)*speedd.value)
else
b = 0
end
if isKeyPressed(VK_D) then
c = 1
XR1 = fovX.value + math.pi- 1.5707963
writeFloat(base+0x0,math.sin(XR1)*speedd.value)
writeFloat(base+0x8,math.cos(XR1)*speedd.value)
else
c = 0
end
if isKeyPressed(VK_S) then
d = 1
XR1=fovX.value+math.pi
writeFloat(base+0x0,math.sin(XR1)*-speedd.value)
writeFloat(base+0x8,math.cos(XR1)*-speedd.value)
else
d = 0
end
if isKeyPressed(VK_W) and isKeyPressed(VK_A) then
XR1 = fovX.value + math.pi+ 1.5707963*0.5
writeFloat(base+0x0,math.sin(XR1)*speedd.value)
writeFloat(base+0x8,math.cos(XR1)*speedd.value)
end
if isKeyPressed(VK_W) and isKeyPressed(VK_D) then
XR1 = fovX.value + math.pi- 1.5707963*0.5
writeFloat(base+0x0,math.sin(XR1)*speedd.value)
writeFloat(base+0x8,math.cos(XR1)*speedd.value)
end
if isKeyPressed(VK_S) and isKeyPressed(VK_A) then
XR1 = fovX.value + math.pi- 1.5707963*0.5
writeFloat(base+0x0,math.sin(XR1)*-speedd.value)
writeFloat(base+0x8,math.cos(XR1)*-speedd.value)
end
if isKeyPressed(VK_S) and isKeyPressed(VK_D) then
XR1 = fovX.value + math.pi+ 1.5707963*0.5
writeFloat(base+0x0,math.sin(XR1)*-speedd.value)
writeFloat(base+0x8,math.cos(XR1)*-speedd.value)
end





if isKeyPressed(VK_SHIFT) then
s = 1
FlyDliang.value = -lopp
else
s = 0
end

if isKeyPressed(VK_SPACE) then
v = 1
FlyDliang.value = lopp
else
v = 0
end

if a == 0 and b == 0 and c == 0 and d == 0 then
FlyXDliang.value = 0
FlyZDliang.value = 0
end

if s == 0 and v == 0 then
FlyDliang.value = 0
end

end
[DISABLE]
goodFlay.destroy()

</AssemblerScript>
                  <CheatEntries>
                    <CheatEntry>
                      <ID>1337193095</ID>
                      <Description>"水平飞行速度"</Description>
                      <ShowAsSigned>0</ShowAsSigned>
                      <VariableType>Float</VariableType>
                      <Address>KaioFly</Address>
                    </CheatEntry>
                    <CheatEntry>
                      <ID>1337193096</ID>
                      <Description>"垂直飞行速度"</Description>
                      <ShowAsSigned>0</ShowAsSigned>
                      <VariableType>Float</VariableType>
                      <Address>KaioFly+4</Address>
                    </CheatEntry>
                  </CheatEntries>
                </CheatEntry>
                <CheatEntry>
                  <ID>1337186841</ID>
                  <Description>"Kaio-基址"</Description>
                  <Color>808000</Color>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>[ENABLE]
alloc(KaioGMMOD,10)
registersymbol(KaioGMMOD)
alloc(KaioTP,100)
registersymbol(KaioTP)
alloc(KaioFly,10)
registersymbol(KaioFly)
[DISABLE]
dealloc(KaioGMMOD,10)
unregistersymbol(KaioGMMOD)
dealloc(KaioTP,100)
unregistersymbol(KaioTP)
