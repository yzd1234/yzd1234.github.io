local qwqX = 300
local qwqY = 300

[ENABLE]
-- 定义一个获取窗口大小的函数
local function GetWindowRect(hWnd)
    local My = createMemoryStream()
    My.Size= 16
    executeCodeLocalEx('user32.GetWindowRect',hWnd,My.Memory)
    local left= My.readDword()
    if left &gt; 0xffffff then
       left= -0xfffffffe~left
    end
    local top=My.readDword()
    local right=My.readDword()
    local bottom=My.readDword()
    My.destroy()
    return left,top,right,bottom
end
-- 获取游戏窗口句柄和标题
handle = findWindow('OGLES')
caption = getWindowCaption(handle)

--------------------------- 定义创建透明窗口的函数
function createTransparentWindow()
    form = createForm()--创建一个窗体对象
    canvas = form.Canvas--获取窗体的画布对象
    form.Color = 0x000000--设置窗体的背景颜色为黑色
    form.Width = getScreenWidth()--设置窗体的大小与屏幕大小相同
    form.Height = getScreenHeight()
    form.FormStyle = 'fsSystemStayOnTop'--设置窗体样式为系统 StayOnTop
    -- 设置窗体的边框样式为无边框
    form.BorderStyle = 'bsNone'
    -- 设置窗体为不透明
    form.setLayeredAttributes(0, 0, LWA_COLORKEY)
end-- 结束 定义创建透明窗口的函数

function draw(mydraw)-- 定义绘制函数，用于在透明窗口上绘制文字
    form.OnPaint = mydraw-- 设置窗体的 OnPaint 事件为 mydraw 函数
end

-- 实现线性插值函数
function lerp(a, b, t)
    return a + (b - a) * t
end

-- 获取渐变色函数
function getGradientColor(startColor, endColor, t)
    return 0x00f2ff
end

-- 创建透明窗口
createTransparentWindow()

-- 在透明窗口上绘制文字
draw(function ()
    -- 获取游戏窗口大小信息
    left, top, right, bottom = GetWindowRect(handle)

    -- 定义渐变色范围和颜色值
    local gradientStart = 0x00f2ff
    local gradientEnd = 0xffb56b

    -- 设置字体样式
    canvas.Font.Size = 18
    canvas.Font.Style = "Bold"

    -- 绘制渐变色文字
    local t = 0.5 -- 渐变色位置，取值范围为 [0, 1]
    local gradientColor = getGradientColor(gradientStart, gradientEnd, t)
--==============================================================================
--==============================================================================
--==============================================================================
    canvas.Brush.Style = bsClear -- 使用透明背景
    canvas.Font.Color = 0x00f2fff -- 设置文字颜色为蓝色
    canvas.TextOut(left+15,top+35, "MisCerNT_Mod 1.0 Beta")
    canvas.TextOut(left+2420,top+35,"KillAura")
    canvas.TextOut(left+2420,top+80,"fly")
    canvas.TextOut(left+2410,top+125,"boat fly")
    canvas.TextOut(left+2370,top+305,"infiniteAura")
    canvas.TextOut(left+2370,top+350,"AutoClicker")
    canvas.TextOut(left+2400,top+215,"FluxSwing")
    canvas.TextOut(left+2375,top+260,"GhostHand")
    canvas.TextOut(left+2400,top+170,"AutoFuck")
    canvas.TextOut(left+2370,top+395,"Velocityxyz")
    canvas.TextOut(left+2330,top+440,"NoSlowDown")
    canvas.TextOut(left+2370,top+485,"TeleportFly")
    canvas.TextOut(left+2350,top+530,"AntiTeleport")
    canvas.TextOut(left+2300,top+575,"InventoryMove")
    canvas.TextOut(left+2340,top+620,"InstantBreak")
    canvas.TextOut(left+2370,top+665,"AutoSwitch")
    canvas.TextOut(left+2320,top+710,"ServerAntikick")
    canvas.TextOut(left+2360,top+755,"WaterSpeed")
    canvas.TextOut(left+2315,top+800,"NoFallDamage")
    canvas.TextOut(left+1155,top+620,".")


--------------------------------------------------------------------------------
end)--绘制结束
