              <Color>FF0000</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>{$lua}
                                                                                                                                                                                    ---Redc
table = GetAddressList()
fov = table.getMemoryRecordByDescription('Fov')
if syntaxcheck then return end
orginalfov = fov.value
[ENABLE]
createThread(function()
while (true) do
if isKeyPressed(VK_C) then
fov.value = 30
else fov.value = orginalfov
end
end
end)
[DISABLE]
fov.value = orginalfov
























































































































































