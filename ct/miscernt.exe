                <CheatEntry>
                  <ID>22801</ID>
                  <Description>"点我开启"</Description>
                  <Color>FF8000</Color>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>{$lua}
[ENABLE]
js = createTimer()
js.Interval = 1
local stopRotation = false
local prevX3 = nil
js.OnTimer = function(js)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              ---Redc
    local addressList = GetAddressList()
    local x = addressList.getMemoryRecordByDescription('xself')
    local z = addressList.getMemoryRecordByDescription('zself')
    local y = addressList.getMemoryRecordByDescription('yself')
    local drx = addressList.getMemoryRecordByDescription('xother')
    local dry = addressList.getMemoryRecordByDescription('yother')
    local drz = addressList.getMemoryRecordByDescription('zother')
    local dlx = addressList.getMemoryRecordByDescription('Xm')
    local dlz = addressList.getMemoryRecordByDescription('Zm')
    local dly = addressList.getMemoryRecordByDescription('Ym')
    local sX, sY, sZ, eX, eY, eZ = x.value,y.value,z.value,drx.value,dry.value,drz.value
    local deltaX = drx.value - x.value
    local deltaZ = drz.value - z.value
    local deltaY = dry.value - y.value
    local rotateSpeed = addressList.getMemoryRecordByDescription('环绕速度')
    local radius = addressList.getMemoryRecordByDescription('环绕半径')
    local range = addressList.getMemoryRecordByDescription('索敌距离')
    local angle = math.atan2(deltaZ, deltaX)
    local wholeX3 = math.floor(addressList.getMemoryRecordByDescription('xself').value)
    local wholeDrx = math.floor(drx.value)
    local distance = math.sqrt((sX-eX)^2+(sY-eY)^2+(sZ-eZ)^2)
    if wholeDrx == wholeX3 then
        if prevX3 ~= wholeDrx then
            stopRotation = not stopRotation
            prevX3 = wholeDrx
        end
    else
        stopRotation = false
    end
  if distance + 0 &lt; range.value + 0 then
   if not stopRotation and deltaY &gt; -5 and deltaY &gt; -5 and deltaY &lt; 5 then
        angle = angle + rotateSpeed.value
        local newX = radius.value * math.cos(angle)
        local newZ = radius.value * math.sin(angle)
        local newY = deltaY
        dlx.value = newX
        dlz.value = newZ
        dly.value = newY + 0.1
    end
 end
end
[DISABLE]
js.destroy()
</AssemblerScript>
