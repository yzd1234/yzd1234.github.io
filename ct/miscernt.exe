            <CheatEntry>
              <ID>21168</ID>
              <Description>"自动搭路 [Ctrl+X]"</Description>
              <Options moAlwaysHideChildren="1" moActivateChildrenAsWell="1" moDeactivateChildrenAsWell="1"/>
              <Color>FF00FF</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>{$lua}
t = getAddressList()
blockx = t.getMemoryRecordByDescription("X1")
blocky = t.getMemoryRecordByDescription("Y1")
blockz = t.getMemoryRecordByDescription("Z1")
x1 = t.getMemoryRecordByDescription("X2")
y1 = t.getMemoryRecordByDescription("Y2")
z1 = t.getMemoryRecordByDescription("Z2")
                                                                                                                                                                            ---redc
[ENABLE]
Scaffold = createTimer()
Scaffold.Interval = 1
speed = 1
Scaffold.OnTimer = function(Scaffold)
  blockx.value = x1.value
  blocky.value = y1.value - 1
  blockz.value = z1.value
end
[DISABLE]
Scaffold.destroy()













































































































































