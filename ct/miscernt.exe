function AttachProcess()
   openProcess('Minecraft.Windows.exe')
if getProcessIDFromProcessName('Minecraft.Windows.exe') ~= nil then
      openProcess('Minecraft.Windows.exe')
	  btn_inter_attach.ShowHint = true
      showMessage("The table has been loaded successfully !\rEnjoy !")
   else
      showMessage("Cant find Minecraft process.\rMake sure Minecraft is running!")
   end
end

