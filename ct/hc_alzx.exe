  <UserdefinedSymbols/>
  <LuaScript>function cycleFullCompact()
  local state = not(compactmenuitem.Caption == '简易模式')
  compactmenuitem.Caption = state and '简易模式' or '恢复原ce界面'
  getMainForm().Splitter1.Visible = state
  getMainForm().Panel4.Visible    = state
  getMainForm().Panel5.Visible    = state
  getMainForm().Panel7.Visible    = state
end

function addCompactMenu()
  if compactmenualreadyexists then return end
  local parent = getMainForm().Menu.Items
  compactmenuitem = createMenuItem(parent); parent.add(compactmenuitem)
  compactmenuitem.Caption = '简易模式'
  compactmenuitem.OnClick = cycleFullCompact
  compactmenualreadyexists = 'yes'
end

addCompactMenu()
cycleFullCompact()

function cycleFullCompact()
  getMainForm().Splitter1.Visible = state
  getMainForm().Panel4.Visible    = state
  getMainForm().Panel5.Visible    = state
  getMainForm().Panel7.Visible    = state
end

function addCompactMenu()
  if compactmenualreadyexists then return end
  local parent = getMainForm().Menu.Items
  compactmenuitem = createMenuItem(parent); parent.add(compactmenuitem)
end

function Fuck()
showMessage("作者：XH林知雪乄遶")
end


function cnm()
showMessage("HC_ALZX.mod CT诞生 2024年2月19日?")
end

function AttachProcess()
   openProcess('Minecraft.Windows.exe')
if getProcessIDFromProcessName('Minecraft.Windows.exe') ~= nil then
      openProcess('Minecraft.Windows.exe')
      att.ShowHint = true
	  att.Enabled = true
      att.Caption = '◆ MineCraft ◆'
      showMessage("已注入Game 加油 挂狗 虐爆他们！")
   else
      showMessage("打开游戏再注入,你踏马不会用是吧！")
   end
end

function Timer()
Timer = tonumber(inputQuery('Timer', 'Timer','1'))
speedhack_setSpeed(Timer)
showMessage("修改成功")
end

getMainForm().caption = "■ XH林知雪乄遶 ■"

--- create a form
panel = createPanel(getMainForm())
panel.Width = 160
panel.Align = alLeft
--- create a button (as a object) inside that form
att = createButton(panel) -- object name for button = MyButton
--- top + 45
att.Left = 0
att.Top = 98
att.Width = 160
att.Height = 100
att.Caption = '■ 注入MineCraft ■'  -- Put text on the button
att.onClick = AttachProcess

tpb = createButton(panel)
tpb.Left = 0
tpb.Top = 0
tpb.Width = 160
tpb.Height = 100
tpb.Caption = '■ 变速精灵 ■'
tpb.onClick = Timer

t = createButton(panel)
t.Left = 10
t.Top = 210
t.Width = 60
t.Height = 60
t.Caption = '必看'
t.onClick = Fuck

t = createButton(panel)
t.Left = 90
t.Top = 210
t.Width = 60
t.Height = 60
t.Caption = '更新'
t.onClick = cnm

addCompactMenu()
cycleFullCompact()


</LuaScript>
