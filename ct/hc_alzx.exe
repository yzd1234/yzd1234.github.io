        <CheatEntry>
          <ID>21986</ID>
          <Description>"                                 ▂▂▂✦ OF 杀戮 ✦▂▂▂ "</Description>
          <Options moHideChildren="1"/>
          <Color>0000FF</Color>
          <GroupHeader>1</GroupHeader>
          <CheatEntries>
            <CheatEntry>
              <ID>21671</ID>
              <Description>"伪真杀 [自动]"</Description>
              <Options moActivateChildrenAsWell="1" moDeactivateChildrenAsWell="1"/>
              <Color>0000FF</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>{$lua}
t = getAddressList()
myX1 = t.getMemoryRecordByDescription("myX1")
myY1 = t.getMemoryRecordByDescription("myY1")
myZ1 = t.getMemoryRecordByDescription("myZ1")

heX1 = t.getMemoryRecordByDescription("heX1")
heY1 = t.getMemoryRecordByDescription("heY1")
heZ1 = t.getMemoryRecordByDescription("heZ1")

heX2 = t.getMemoryRecordByDescription("heX2")
heY2 = t.getMemoryRecordByDescription("heY2")
heZ2 = t.getMemoryRecordByDescription("heZ2")

heX3 = t.getMemoryRecordByDescription("heX3")
heY3 = t.getMemoryRecordByDescription("heY3")
heZ3 = t.getMemoryRecordByDescription("heZ3")

heXa = t.getMemoryRecordByDescription("heXa")
heYa = t.getMemoryRecordByDescription("heYa")
heZa = t.getMemoryRecordByDescription("heZa")
jm = t.getMemoryRecordByDescription("界面检测")

[ENABLE]
weizhenshac = createTimer()
weizhenshac.Interval = 1
speed = 1
weizhenshac.OnTimer = function()

if (jm.value - 778335592)^2 &lt; 1 then
heX1.value = myX1.value -0.3
heY1.value = myY1.value +0
heZ1.value = myZ1.value -0.3
heX2.value = myX1.value +0.3
heY2.value = myY1.value +1.8
heZ2.value = myZ1.value +0.3
mouse_event(MOUSEEVENTF_LEFTDOWN)
mouse_event(MOUSEEVENTF_LEFTUP)
end
end
[DISABLE]
weizhenshac.destroy()
