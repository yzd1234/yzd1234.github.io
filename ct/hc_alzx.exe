                <CheatEntry>
                  <ID>12816</ID>
                  <Description>"当 ’动量 [Y]‘ 大于5时   按一次P"</Description>
                  <Color>0000FF</Color>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>{$lua}
t = getAddressList()
R = t.getMemoryRecordByDescription("动量 [Y]")
[ENABLE]
QairLee = createTimer()
QairLee.Interval = 1
speed = 1
QairLee.OnTimer = function(QairLee)
if R.value + 0 &gt; 5 + 0 then
  doKeyPress(VK_P)
  sleep(1)
end
end
[DISABLE]
QairLee.destroy()
</AssemblerScript>
                </CheatEntry>
                <CheatEntry>
                  <ID>12822</ID>
                  <Description>"走两步是为了加载动量前置"</Description>
                  <Color>0000FF</Color>
                  <GroupHeader>1</GroupHeader>
                </CheatEntry>
              </CheatEntries>
            </CheatEntry>
