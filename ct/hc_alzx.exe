        <CheatEntry>
          <ID>21084</ID>
          <Description>"                                 ▂▂▂✦ 数值传送 ✦▂▂▂ "</Description>
          <Options moHideChildren="1"/>
          <Color>FF0000</Color>
          <GroupHeader>1</GroupHeader>
          <Hotkeys>
            <Hotkey>
              <Action>Toggle Activation</Action>
              <Keys/>
              <ID>0</ID>
            </Hotkey>
          </Hotkeys>
          <CheatEntries>
            <CheatEntry>
              <ID>20966</ID>
              <Description>"动量传送"</Description>
              <Options moHideChildren="1"/>
              <Color>FF0000</Color>
              <GroupHeader>1</GroupHeader>
              <Hotkeys>
                <Hotkey>
                  <Action>Toggle Activation</Action>
                  <Keys/>
                  <ID>0</ID>
                </Hotkey>
              </Hotkeys>
              <CheatEntries>
                <CheatEntry>
                  <ID>21275</ID>
                  <Description>"启动总tp"</Description>
                  <Options moActivateChildrenAsWell="1" moDeactivateChildrenAsWell="1"/>
                  <Color>FF0000</Color>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>{$lua}
t = getAddressList()
X1 = t.getMemoryRecordByDescription("x1")
Y1 = t.getMemoryRecordByDescription("y1")
Z1 = t.getMemoryRecordByDescription("z1")
X2 = t.getMemoryRecordByDescription("坐标x")
Y2 = t.getMemoryRecordByDescription("坐标y")
Z2 = t.getMemoryRecordByDescription("坐标z")
X3 = t.getMemoryRecordByDescription("X vel")
Y3 = t.getMemoryRecordByDescription("Y vel")
Z3 = t.getMemoryRecordByDescription("Z vel")
[ENABLE]
sd = createTimer()
sd.Interval = 1
speed = 1
sd.OnTimer = function(sd)
if isKeyPressed(VK_W) then
  X3.value = X2.value - X1.value
  Y3.value = Y2.value - Y1.value
  Z3.value = Z2.value - Z1.value
  sleep(60)
  end
end
[DISABLE]
sd.destroy()


</AssemblerScript>
                </CheatEntry>
