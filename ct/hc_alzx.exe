        </CheatEntry>
        <CheatEntry>
          <ID>22107</ID>
          <Description>"                                ▂▂▂✦ 环绕攻击 ✦▂▂▂ "</Description>
          <Color>0000FF</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>{$lua}
t = getAddressList()
X1 = t.getMemoryRecordByDescription("x1")
Y1 = t.getMemoryRecordByDescription("y1")
Z1 = t.getMemoryRecordByDescription("z1")
X2 = t.getMemoryRecordByDescription("x2")
Y2 = t.getMemoryRecordByDescription("y2")
Z2 = t.getMemoryRecordByDescription("z2")
X3 = t.getMemoryRecordByDescription("X vel")
Y3 = t.getMemoryRecordByDescription("Y vel")
Z3 = t.getMemoryRecordByDescription("Z vel")
X4 = t.getMemoryRecordByDescription("坐标x⠀")
Y4 = t.getMemoryRecordByDescription("坐标y⠀")
Z4 = t.getMemoryRecordByDescription("坐标z⠀")
[ENABLE]
------------------------------------------
sd = createTimer()
sd.Interval = 1
speed = 1
sd.OnTimer = function(sd)
------------------------------------------
----------------------------------------------|
if isKeyPressed(VK_CONTROL) then--[左Ctrl条件]|
  if isKeyPressed(VK_F) then--[第二层H条件]   |
------------通过条件后执行算法----------------|
X3.value = X2.value - X1.value + 0.5--&lt;]
Y3.value = Y2.value - Y1.value + 0  --&lt;--算法1
Z3.value = Z2.value - Z1.value + 0.5--&lt;]
--                                       \
sleep(50)--&lt;--&lt;--&lt;--&lt;--&lt;--&lt;延迟50毫秒执行下一个算法
--                                      ./
X3.value = X2.value - X1.value + 0.5 --&lt;]
Y3.value = Y2.value - Y1.value + 1   --&lt;--算法2
Z3.value = Z2.value - Z1.value + -0.5--&lt;]
--                                       \
sleep(50)--&lt;--&lt;--&lt;--&lt;--&lt;--&lt;延迟50毫秒执行下一个算法
--                                      ./
X3.value = X2.value - X1.value + -0.5--&lt;]
Y3.value = Y2.value - Y1.value + 1   --&lt;--算法3
Z3.value = Z2.value - Z1.value + -0.5--&lt;]
--                                       \
sleep(50)--&lt;--&lt;--&lt;--&lt;--&lt;--&lt;延迟50毫秒执行下一个算法
--                                      ./
X3.value = X2.value - X1.value + -0.5--&lt;]
Y3.value = Y2.value - Y1.value + 1   --&lt;--算法4
Z3.value = Z2.value - Z1.value + 0.5 --&lt;]
  end
end
----------------------------------------------|
if isKeyPressed(VK_SHIFT) then--[SHIFT条件]   |
  if isKeyPressed(VK_F) then--[第二层F条件]   |
------------通过条件后执行算法----------------|
X4.value = X1.value---]     算法
Y4.value = Y1.value --|--[记录坐标]
Z4.value = Z1.value---]
  end
end
----------------------------------------------|
if isKeyPressed(VK_SHIFT) then--[SHIFT条件]   |
  if isKeyPressed(VK_G) then--[第二层G条件]   |
------------通过条件后执行算法----------------|
X3.value = X4.value - X1.value---]     算法
Y3.value = Y4.value - Y1.value --|--[传送坐标]
Z3.value = Z4.value - Z1.value---]
  end
end
---
end
[DISABLE]
sd.destroy()
</AssemblerScript>
        </CheatEntry>
