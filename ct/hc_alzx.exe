            <CheatEntry>
              <ID>22122</ID>
              <Description>"停止方块坐标更改[核心其一]"</Description>
              <Options moActivateChildrenAsWell="1" moDeactivateChildrenAsWell="1"/>
              <Color>FF0000</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>{$lua}
t = getAddressList()
blockx = t.getMemoryRecordByDescription("方块x")
blocky = t.getMemoryRecordByDescription("方块y")
blockz = t.getMemoryRecordByDescription("方块z")
x1 = t.getMemoryRecordByDescription("x1")
y1 = t.getMemoryRecordByDescription("y1")
z1 = t.getMemoryRecordByDescription("z1")

[ENABLE]
sd = createTimer()
sd.Interval = 1
speed = 1
sd.OnTimer = function(sd)

blockx.value = x1.value
blocky.value = y1.value - 1
blockz.value = z1.value

end
[DISABLE]
sd.destroy()



</AssemblerScript>
            </CheatEntry>
            <CheatEntry>
              <ID>22123</ID>
              <Description>"FastPlace[快速放置]"</Description>
              <Color>FF0000</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>[ENABLE]
aobscanmodule(FastPlace,Minecraft.Windows.exe,6A 11 FF 90 ?? ?? ?? ?? 8B 7D E4 85 FF 74 21 83 CE FF 8B C6 F0 0F C1 47 04)
registersymbol(FastPlace)
FastPlace:
db 6A 39 FF 90
[DISABLE]
FastPlace:
db 6A 11 FF 90
unregistersymbol(FastPlace)
</AssemblerScript>
            </CheatEntry>
            <CheatEntry>
              <ID>22124</ID>
              <Description>"普通搭路[在脚下固定放一个方块]"</Description>
              <Options moActivateChildrenAsWell="1" moDeactivateChildrenAsWell="1"/>
              <Color>FF0000</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>{$lua}
t = getAddressList()
blockx = t.getMemoryRecordByDescription("方块x")
blocky = t.getMemoryRecordByDescription("方块y")
blockz = t.getMemoryRecordByDescription("方块z")
x1 = t.getMemoryRecordByDescription("x1")
y1 = t.getMemoryRecordByDescription("y1")
z1 = t.getMemoryRecordByDescription("z1")

[ENABLE]
sd = createTimer()
sd.Interval = 1
speed = 1
sd.OnTimer = function(sd)

blockx.value = x1.value
blocky.value = y1.value - 1.0
blockz.value = z1.value


end
[DISABLE]
sd.destroy()



</AssemblerScript>
            </CheatEntry>
