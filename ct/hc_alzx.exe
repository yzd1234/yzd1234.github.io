        <CheatEntry>
          <ID>21029</ID>
          <Description>"                             ▂▂▂✦ [着火]瞬移打人 ✦▂▂▂"</Description>
          <Options moAlwaysHideChildren="1" moActivateChildrenAsWell="1" moDeactivateChildrenAsWell="1"/>
          <Color>004DFF</Color>
          <GroupHeader>1</GroupHeader>
          <Hotkeys>
            <Hotkey>
              <Action>Toggle Activation</Action>
              <Keys/>
              <ID>0</ID>
            </Hotkey>
          </Hotkeys>
          <CheatEntries>
            <CheatEntry>
              <ID>21030</ID>
              <Description>"被火烫的瞬移打人(doge)"</Description>
              <Options moActivateChildrenAsWell="1" moDeactivateChildrenAsWell="1"/>
              <Color>80FF00</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>{$lua}
t = getAddressList()
X1 = t.getMemoryRecordByDescription("x1")
Y1 = t.getMemoryRecordByDescription("y1")
Z1 = t.getMemoryRecordByDescription("z1")
X2 = t.getMemoryRecordByDescription("x2")
Y2 = t.getMemoryRecordByDescription("y2")
Z2 = t.getMemoryRecordByDescription("z2")
X3 = t.getMemoryRecordByDescription("X vel")
Y3 = t.getMemoryRecordByDescription("Y vel")
Z3 = t.getMemoryRecordByDescription("Z vel")
[ENABLE]
sd = createTimer()
sd.Interval = 1
speed = 0.01
sd.OnTimer = function(sd)
if isKeyPressed(VK_A) then
  X3.value = X2.value - X1.value
  Z3.value = Z2.value - Z1.value
end
if isKeyPressed(VK_D) then
  X3.value = X2.value - X1.value + 2.7
  Z3.value = Z2.value - Z1.value + 2.7
end
end
[DISABLE]
sd.destroy()
</AssemblerScript>
