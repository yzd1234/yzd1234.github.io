        <CheatEntry>
          <ID>22131</ID>
          <Description>"                                 ▂▂▂✦ 无摔飞行 ✦▂▂▂ "</Description>
          <Options moAlwaysHideChildren="1"/>
          <Color>FF0000</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>{$lua}
t = getAddressList()
XM = t.getMemoryRecordByDescription("self x motion")
YM = t.getMemoryRecordByDescription("self y motion")
ZM = t.getMemoryRecordByDescription("self z motion")
DM = t.getMemoryRecordByDescription("地面")
KM = t.getMemoryRecordByDescription("高空")
FZ = t.getMemoryRecordByDescription("飞行状态")
FQ = t.getMemoryRecordByDescription("飞行权限")
blink = t.getMemoryRecordByDescription("Blink")
time = t.getMemoryRecordByDescription("Nofall计时器")
jish = t.getMemoryRecordByDescription("Nofall计时器开关")
[ENABLE]
OFnofall = createTimer()
OFnofall.Interval = 1
sleed = 1
OFnofall.OnTimer = function(OFnofall)
FQ.value = 1



-------------------------------------------当飞行移动时 开blink 开计时器
   if FZ.value + 0 &gt; 0.5 + 0 then                                 ---
     if (XM.value + ZM.value + YM.value)^2 &gt; 0.007 then            ---
       blink.Active = true  --开启                                  ---
       jish.value = 1 + 0                                           ---
     end                                                           ---
----------------------------------------------计时器
   if jish.value + 0 &gt; 0 + 0 then             ---
      time.value = time.value + 1             ---
     if time.value + 0 &gt; 39 + 0 then           ---
        blink.Active = false  --关闭             ---
        time.value = 0 + 0                        ---
        jish.value = 0 + 0                       ---
     end
   end                                        ---
------------------------------------------------

    if (XM.value + ZM.value + YM.value)^2 &lt; 0.007 then -----空中不动时常开blink
      blink.Active = true  --开启
    end
--------------------------------------------------

end--当飞行时












-------------------------------------------------------------------------------
    if FZ.value + 0 &lt; 0.5 + 0 then                              -----当不飞行时
     if KM.value + 0 &gt; 0.1 + 0 then
        blink.Active = true  --开启
     end
     if KM.value + 0 &lt; 0.1 + 0 then
        blink.Active = false  --关闭此脚本
     end
    end
-------------------------------------------------------------------------------







end--大循环结束
[DISABLE]
blink.Active = false  --关闭此脚本
  FQ.value = 0
OFnofall.destroy()
</AssemblerScript>
