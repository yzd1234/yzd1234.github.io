            <CheatEntry>
              <ID>3360</ID>
              <Description>"虚空锁敌"</Description>
              <Color>00FF00</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>{$lua}
t = getAddressList()
X1 = t.getMemoryRecordByDescription("x1")
Y1 = t.getMemoryRecordByDescription("y1")
Z1 = t.getMemoryRecordByDescription("z1")
X2 = t.getMemoryRecordByDescription("x2")
Y2 = t.getMemoryRecordByDescription("y2")
Z2 = t.getMemoryRecordByDescription("z2")
[ENABLE]
sd = createTimer()
sd.Interval = 1
speed = 1
sd.OnTimer = function(sd)
if isKeyPressed(VK_W) then
  X2.value = X1.value
  Y2.value = Y1.value + 1.5
  Z2.value = Z1.value
end
if isKeyPressed(VK_A) then
  X2.value = X1.value
  Y2.value = Y1.value + 1.5
  Z2.value = Z1.value
end
if isKeyPressed(VK_S) then
  X2.value = X1.value
  Y2.value = Y1.value + 1.5
  Z2.value = Z1.value
end
if isKeyPressed(VK_D) then
  X2.value = X1.value
  Y2.value = Y1.value + 1.5
  Z2.value = Z1.value
end
end
[DISABLE]
sd.destroy()
</AssemblerScript>
