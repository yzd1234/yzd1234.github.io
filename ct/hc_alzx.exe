        <CheatEntry>
          <ID>22004</ID>
          <Description>"                                 ▂▂▂✦ 秒回地面 ✦▂▂▂ "</Description>
          <Options moAlwaysHideChildren="1"/>
          <Color>FF0000</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>{$lua}
t = getAddressList()
TJ = t.getMemoryRecordByDescription("台阶")
myY1 = t.getMemoryRecordByDescription("myY1")
myY2 = t.getMemoryRecordByDescription("myY2")
DM = t.getMemoryRecordByDescription("地面")
[ENABLE]
----------------------------------如果在虚空
if myY1.value + 0 &lt; -299 + 0 then
   myY1.value = -300 + 0
   myY2.value = 600 + 0
end
----------------------------------如果在高空
if DM.value + 0 &lt; 257 + 0 then
   myY1.value = -300 + 0
   myY2.value = 600 + 0
end
----------------------------------如果在矿洞
TJ.value = 300 + 0
myY2.value = 300 + 0

[DISABLE]
TJ.value = -1
myY2.value = myY1.value + 1.8
</AssemblerScript>
